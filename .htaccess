RewriteEngine On
RewriteBase /audit-system/

# Remove .php extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [L]

# Redirect .php to clean URL
RewriteCond %{THE_REQUEST} \s/audit-system/([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]